generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id             String    @id @default(uuid())
  name           String?
  email          String    @unique
  emailVerified  DateTime?
  image          String?
  passwordHash   String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  isBusinessUser Boolean   @default(false)
  inquiries      Inquiry[]
}

model Admin {
  id           String   @id @default(uuid())
  name         String?
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  blogs        Blog[]
}

model Category {
  id          String    @id @default(uuid())
  name        String    @unique
  slug        String    @unique
  description String?
  image       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  products    Product[]
}

model Product {
  id            String              @id @default(uuid())
  title         String
  slug          String              @unique
  description   String
  price         Decimal             @db.Decimal(12, 2)
  dealerPrice   Decimal?            @db.Decimal(12, 2)
  sku           String              @unique
  gemType       String
  carat         Float
  color         String?
  clarity       String?
  cut           String?
  origin        String?
  certification String?
  certNumber    String?             @unique
  featured      Boolean             @default(false)
  inStock       Boolean             @default(true)
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  categoryId    String
  faqs          Faq[]
  inquiries     Inquiry[]
  category      Category            @relation(fields: [categoryId], references: [id])
  collections   ProductCollection[]
  images        ProductImage[]
  reviews       Review[]
}

model ProductImage {
  id        String   @id @default(uuid())
  url       String
  isPrimary Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model Inquiry {
  id          String           @id @default(uuid())
  name        String
  email       String
  phone       String?
  message     String
  status      String           @default("PENDING")
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  productId   String?
  inquiryType String           @default("DIRECT")
  productSkus String?
  userId      String?
  product     Product?         @relation(fields: [productId], references: [id])
  user        User?            @relation(fields: [userId], references: [id])
  messages    InquiryMessage[]
}

model InquiryMessage {
  id        String   @id @default(uuid())
  inquiryId String
  sender    String
  senderId  String?
  message   String
  createdAt DateTime @default(now())
  inquiry   Inquiry  @relation(fields: [inquiryId], references: [id], onDelete: Cascade)
}

model Dealer {
  id           String   @id @default(uuid())
  companyName  String
  taxId        String?
  website      String?
  address      String?
  businessType String?
  status       String   @default("PENDING")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model BlogCategory {
  id        String   @id @default(uuid())
  name      String   @unique
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  blogs     Blog[]
}

model Blog {
  id            String       @id @default(uuid())
  title         String
  slug          String       @unique
  content       String
  excerpt       String?
  featuredImage String?
  published     Boolean      @default(false)
  publishedAt   DateTime?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  authorId      String
  categoryId    String
  author        Admin        @relation(fields: [authorId], references: [id])
  category      BlogCategory @relation(fields: [categoryId], references: [id])
}

model Setting {
  id    String @id @default(uuid())
  key   String @unique
  value String
}

model Collection {
  id          String              @id @default(uuid())
  name        String              @unique
  slug        String              @unique
  description String?
  imageUrl    String?
  featured    Boolean             @default(false)
  order       Int                 @default(0)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  products    ProductCollection[]
}

model ProductCollection {
  productId    String
  collectionId String
  collection   Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  product      Product    @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@id([productId, collectionId])
}

model Menu {
  id           String   @id @default(uuid())
  label        String
  href         String
  order        Int      @default(0)
  isActive     Boolean  @default(true)
  parentMenuId String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  parentMenu   Menu?    @relation("MenuSubmenus", fields: [parentMenuId], references: [id], onDelete: Cascade)
  submenus     Menu[]   @relation("MenuSubmenus")
}

model Review {
  id        String   @id @default(uuid())
  author    String
  location  String?
  rating    Int      @default(5)
  title     String
  comment   String
  approved  Boolean  @default(false)
  productId String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  product   Product? @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model Faq {
  id        String   @id @default(uuid())
  question  String
  answer    String
  order     Int      @default(0)
  category  String   @default("Acquisition")
  productId String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  product   Product? @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model Atelier {
  id          String   @id @default(uuid())
  city        String
  name        String
  role        String
  phone       String
  address     String
  services    String[]
  description String
  mapCoords   String
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model NewsletterSubscriber {
  id        String   @id @default(uuid())
  email     String   @unique
  createdAt DateTime @default(now())
}


